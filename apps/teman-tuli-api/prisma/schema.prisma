generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FeedbackRating {
  POOR
  OKAY
  GOOD
  EXCELLENT
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  goal         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  transcriptSessions TranscriptSession[]
  captionFeedback     CaptionFeedback[]
}

model TranscriptSession {
  id           String   @id @default(cuid())
  userId       String
  title        String
  className    String?
  languageCode String   @default("id-ID")
  fullText     String
  notes        String?
  startedAt    DateTime
  endedAt      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  segments  TranscriptSegment[]
  feedbacks CaptionFeedback[]

  @@index([userId, startedAt])
}

model TranscriptSegment {
  id        String @id @default(cuid())
  sessionId String
  text      String
  startMs   Int
  endMs     Int?

  session TranscriptSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, startMs])
}

model CaptionFeedback {
  id        String         @id @default(cuid())
  userId    String
  sessionId String
  rating    FeedbackRating
  comment   String?
  createdAt DateTime       @default(now())

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  session TranscriptSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}
